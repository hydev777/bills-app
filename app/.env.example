# Copia a .env y ajusta si es necesario.
# Environment: local | dev | prod (o --dart-define=ENV=prod)
ENV=dev

# Local: inicia una API SQLite embebida dentro de la app
# ENV=local

# Development - backend en local
BASE_URL_DEV=http://localhost:3000

# Production - sustituir por tu URL real
BASE_URL_PROD=https://api.example.com

# Android emulator (backend en el host): BASE_URL_DEV=http://10.0.2.2:3000
